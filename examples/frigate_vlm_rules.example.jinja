{#
  ============================================================================
  EXAMPLE VLM rule macros  (anonymized template — copy & adapt)
  ============================================================================
  Install your own edited copy at:
      /config/custom_templates/frigate_vlm_rules.jinja
  Then point a camera automation's "VLM Rules" input at one macro:
      {% from 'frigate_vlm_rules.jinja' import perimeter_camera_rules %}{{ perimeter_camera_rules(vlm, gate, vlm_zones, camera_name) }}

  ----------------------------------------------------------------------------
  CONTRACT — every macro receives:
    vlm         dict  — the parsed, TYPE-COERCED VLM output for this event
                        (fields are WHATEVER YOUR CAMERA PROMPT EMITS — the
                        names below are illustrative; use your own)
    gate        bool  — true when confidence/image_quality pass the automation's
                        gate thresholds (set in the blueprint UI)
    vlm_zones   list  — Frigate zones the object entered (from the event)
    camera_name str   — human-friendly camera name

  …and must emit EXACTLY ONE dict literal:
    {'notify': bool,
     'priority': 'normal'|'high'|'critical',
     'title': str,
     'message': str,
     'siren': bool          (optional),
     'siren_profile': 'urgent'|'soft'|'scareoff'  (optional)}

  CRITICAL SYNTAX: use {%- -%} trimming so the rendered output starts at '{'
  with no leading whitespace — Home Assistant only parses it back into a dict
  when it does. (This is the #1 gotcha.) Access fields with | default(...)
  everywhere, because the VLM may omit a field.

  DESIGN PATTERNS shown below:
    1. SECURITY rules first, UNGATED — based on Frigate FACTS (which zone, what
       time). These must fire even when night IR makes image_quality "poor",
       so they sit ABOVE the `not gate` check and never depend on `gate`.
    2. VISION rules after `not gate` — they rely on the VLM actually seeing
       things clearly, so they require the quality gate.
    3. First match wins → order by severity (critical → high → normal).
    4. 'siren' is OPT-IN per rule; 'critical' priority does NOT imply a siren.
       Sirens only sound if the automation also has "Enable Siren" on.
    5. "Known person only, nothing else interesting" → return notify:false
       (intentionally SILENT) so routine family activity doesn't spam you.
  ============================================================================
#}

{#- SMOKE TEST: fire a critical on any detected person. Swap in during
    commissioning to prove the full pipeline per camera, then replace with a
    real macro. -#}
{%- macro smoketest_rules(vlm, gate, vlm_zones, camera_name) -%}
{%- if gate and (vlm.person_detected | default(false)) -%}
{{ {'notify': true, 'priority': 'critical',
    'title': '🧪 SMOKETEST — ' ~ camera_name,
    'message': 'Person detected. ' ~ (vlm.summary | default(''))} }}
{%- else -%}
{{ {'notify': false} }}
{%- endif -%}
{%- endmacro -%}


{#- ============================================================
    EXAMPLE A — POOL / HAZARD-AREA CAMERA
    Demonstrates: zone-fact security rule (ungated), night rule (ungated),
    gated child-hazard rules with siren opt-in, family-silent default.
    ============================================================ -#}
{%- macro pool_camera_rules(vlm, gate, vlm_zones, camera_name) -%}
{#- Fixed-hours night window 22:00–05:59. Edit the hour list to taste, or swap
    for: is_state('sun.sun', 'below_horizon'). -#}
{%- set is_night = now().hour in [22, 23, 0, 1, 2, 3, 4, 5] -%}

{#- 1) UNGATED security: presence in an off-limits zone, any time/quality. -#}
{%- if '<restricted_zone>' in vlm_zones -%}
{{ {'notify': true, 'priority': 'critical', 'siren': true, 'siren_profile': 'urgent',
    'title': '🚨 ' ~ camera_name ~ ' — person in restricted area',
    'message': vlm.summary | default('Person detected in a restricted area!')} }}
{#- 2) UNGATED security: any person at night. -#}
{%- elif is_night -%}
{{ {'notify': true, 'priority': 'critical',
    'title': '🚨 ' ~ camera_name ~ ' — person at night',
    'message': vlm.summary | default('Person detected at night')} }}

{#- 3) GATED vision rules from here down. -#}
{%- elif not gate -%}
{{ {'notify': false} }}
{%- elif (vlm.child_in_water | default(false)) and not (vlm.child_supervised | default(true)) -%}
{{ {'notify': true, 'priority': 'critical', 'siren': true, 'siren_profile': 'urgent',
    'title': '🚨 Pool — child unsupervised in water',
    'message': vlm.summary | default('Unsupervised child in the pool!')} }}
{%- elif (vlm.child_near_edge | default(false)) and not (vlm.child_supervised | default(true)) -%}
{{ {'notify': true, 'priority': 'critical', 'siren': true, 'siren_profile': 'soft',
    'title': '🚨 Pool — child near edge',
    'message': vlm.summary | default('Unsupervised child near the pool edge!')} }}
{%- elif (vlm.unknown_person_in_frame | default(false)) -%}
{{ {'notify': true, 'priority': 'high',
    'title': '⚠️ ' ~ camera_name ~ ' — unknown person',
    'message': vlm.summary | default('Unknown person detected')} }}
{#- Known-person-only presence → SILENT. -#}
{%- else -%}
{{ {'notify': false} }}
{%- endif -%}
{%- endmacro -%}


{#- ============================================================
    EXAMPLE B — PERIMETER / FRONT CAMERA
    Demonstrates: severity-ordered gated rules, multi-field OR conditions,
    category-based delivery, package theft, family-silent default.
    No sirens here by default (tune to taste).
    ============================================================ -#}
{%- macro perimeter_camera_rules(vlm, gate, vlm_zones, camera_name) -%}
{%- if not gate -%}
{{ {'notify': false} }}
{%- elif (vlm.child_unsupervised_near_exit | default(false))
        and ((vlm.pedestrian_gate_open | default(false)) or (vlm.vehicle_gate_open | default(false))) -%}
{{ {'notify': true, 'priority': 'critical',
    'title': '🚨 ' ~ camera_name ~ ' — child near open gate',
    'message': vlm.summary | default('Unsupervised child near an open gate!')} }}
{%- elif (vlm.suspicious_behavior | default(false))
        or (vlm.non_standard_approach | default(false))
        or (vlm.unknown_vehicle_on_property | default(false)) -%}
{{ {'notify': true, 'priority': 'high',
    'title': '⚠️ ' ~ camera_name ~ ' — suspicious activity',
    'message': vlm.suspicious_behavior_details | default(vlm.summary | default('Suspicious activity outside'))} }}
{%- elif (vlm.package_being_taken | default(false)) -%}
{{ {'notify': true, 'priority': 'high',
    'title': '📦 ' ~ camera_name ~ ' — package being taken',
    'message': vlm.summary | default('Someone is taking a package')} }}
{%- elif ((vlm.person_category | default('')) == 'delivery') or (vlm.package_being_delivered | default(false)) -%}
{{ {'notify': true, 'priority': 'normal',
    'title': '📦 ' ~ camera_name ~ ' — delivery',
    'message': vlm.summary | default('Delivery')} }}
{%- elif (vlm.unknown_person_in_frame | default(false)) -%}
{{ {'notify': true, 'priority': 'high',
    'title': '⚠️ ' ~ camera_name ~ ' — unknown person',
    'message': vlm.summary | default('Unknown person outside')} }}
{#- Known-person-only presence → SILENT. -#}
{%- else -%}
{{ {'notify': false} }}
{%- endif -%}
{%- endmacro -%}


{#- ============================================================
    EXAMPLE C — ELEVATED / BALCONY CAMERA
    Demonstrates: stacking several UNGATED safety rules (a child-bedroom
    balcony must alert regardless of night image quality), with sirens, before
    falling through to the gated perimeter rules.
    ============================================================ -#}
{%- macro balcony_camera_rules(vlm, gate, vlm_zones, camera_name) -%}
{%- set is_night = now().hour in [22, 23, 0, 1, 2, 3, 4, 5] -%}

{#- UNGATED balcony safety (highest priority, fires on poor night IR too). -#}
{%- if (vlm.child_climbing_railing | default(false)) -%}
{{ {'notify': true, 'priority': 'critical', 'siren': true, 'siren_profile': 'urgent',
    'title': '🚨 Balcony — child climbing railing',
    'message': vlm.summary | default('A child is climbing on the balcony railing!')} }}
{%- elif (vlm.child_on_balcony | default(false)) and not (vlm.adults_count | default(0) > 0) -%}
{{ {'notify': true, 'priority': 'critical', 'siren': true, 'siren_profile': 'soft',
    'title': '🚨 Balcony — child alone',
    'message': vlm.summary | default('A child is alone on the balcony!')} }}
{%- elif (vlm.unknown_person_on_balcony | default(false)) -%}
{{ {'notify': true, 'priority': 'critical',
    'title': '🚨 Balcony — non-family person',
    'message': vlm.summary | default('A non-family person is on the balcony!')} }}
{%- elif (vlm.balcony_occupied | default(false)) and is_night -%}
{{ {'notify': true, 'priority': 'critical', 'siren': true, 'siren_profile': 'soft',
    'title': '🚨 Balcony — person at night',
    'message': vlm.summary | default('Person on the balcony at night!')} }}

{#- GATED perimeter rules below (this camera also sees the yard/street). -#}
{%- elif not gate -%}
{{ {'notify': false} }}
{%- elif (vlm.suspicious_behavior | default(false))
        or (vlm.person_observing_property | default(false)) -%}
{{ {'notify': true, 'priority': 'high',
    'title': '⚠️ ' ~ camera_name ~ ' — suspicious activity',
    'message': vlm.suspicious_behavior_details | default(vlm.summary | default('Suspicious activity outside'))} }}
{%- elif (vlm.unknown_person_in_frame | default(false)) -%}
{{ {'notify': true, 'priority': 'high',
    'title': '⚠️ ' ~ camera_name ~ ' — unknown person',
    'message': vlm.summary | default('Unknown person outside')} }}
{#- Known-person-only presence → SILENT. -#}
{%- else -%}
{{ {'notify': false} }}
{%- endif -%}
{%- endmacro -%}
